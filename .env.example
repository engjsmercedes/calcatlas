# ============================================================
# Calc Atlas — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only.
# ============================================================


# ------------------------------------------------------------
# Site
# ------------------------------------------------------------

# The canonical URL of the site — used in metadata and sitemap
# Default: https://calcatlas.app
NEXT_PUBLIC_SITE_URL=https://calcatlas.app


# ------------------------------------------------------------
# AI summaries (optional)
# Enables the calculator guide search and decision summary features.
# Without this, those features silently degrade to static fallbacks.
# ------------------------------------------------------------

# Your Anthropic API key
ANTHROPIC_API_KEY=

# The model to use for summaries (default: claude-haiku-4-5)
AI_SUMMARY_MODEL=claude-haiku-4-5


# ------------------------------------------------------------
# Email — contact form and calculator feedback
# Uses Resend (https://resend.com) to send email.
# Without this, contact form and feedback submissions are silently dropped.
# ------------------------------------------------------------

# Your Resend API key
RESEND_API_KEY=

# The address that receives contact and feedback emails
CONTACT_TO_EMAIL=you@example.com

# The from address shown on outgoing emails
# Default: Calc Atlas <onboarding@resend.dev>
CONTACT_FROM_EMAIL=Calc Atlas <onboarding@resend.dev>


# ------------------------------------------------------------
# Cloudflare Turnstile — bot protection on the contact form (optional)
# Without these, the contact form renders without bot protection.
# Get keys at https://dash.cloudflare.com → Turnstile
# ------------------------------------------------------------

# The public site key (exposed to browser)
NEXT_PUBLIC_TURNSTILE=

# The secret key used to verify tokens server-side
TURNSTILE_SECRET=


# ------------------------------------------------------------
# Analytics (optional)
# Google Analytics 4 measurement ID.
# Without this, no analytics tracking is loaded.
# ------------------------------------------------------------

# e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
